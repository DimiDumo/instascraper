# Database Configuration (SQLite)
DATABASE_PATH=./data/instascraper.db

# Image storage directory
IMAGE_DIR=./data/images

# HTTP server (Hono on Bun)
API_PORT=3737
WEB_PORT=5173

# Agent harness used for scrape subprocesses.
# AGENT_CMD = binary; AGENT_ARGS = whitespace-split flags inserted before the prompt.
# Default: `claude -p --chrome --dangerously-skip-permissions "<prompt>"`.
#   -p                              non-interactive print mode
#   --chrome                        enable Claude-in-Chrome integration so the
#                                   subprocess uses the user's real, logged-in
#                                   Chrome session (not Playwright's headless one)
#   --dangerously-skip-permissions  auto-approve MCP tool calls so subprocess
#                                   doesn't hang waiting for permission prompts
# Other harness examples:
#   AGENT_CMD=opencode  AGENT_ARGS=run
#   AGENT_CMD=echo      AGENT_ARGS=dry-run:    # no-op for testing the queue/UI
AGENT_CMD=claude
AGENT_ARGS=-p --chrome --dangerously-skip-permissions --output-format stream-json --verbose
