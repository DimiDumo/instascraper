# ─── Cloud (D1 + R2 via Cloudflare Worker) ────────────────────────────────────
# Base URL of the deployed Worker.
CLOUD_API_URL=https://instascraper-api.<your-subdomain>.workers.dev

# Cloudflare Access Service Token (Zero Trust → Access → Service Auth → create token).
# These two headers are sent on every Worker call and bypass the Access login flow.
CF_ACCESS_CLIENT_ID=
CF_ACCESS_CLIENT_SECRET=

# R2 S3 credentials (R2 dashboard → Manage API tokens → Object Read & Write).
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=instascraper-images

# ─── Local server (orchestration only) ────────────────────────────────────────
API_PORT=3737
WEB_PORT=5173

# Agent harness used for scrape subprocesses.
# AGENT_CMD = binary; AGENT_ARGS = whitespace-split flags inserted before the prompt.
# Default: `claude -p --chrome --dangerously-skip-permissions "<prompt>"`.
AGENT_CMD=claude
AGENT_ARGS=-p --chrome --dangerously-skip-permissions --output-format stream-json --verbose


HUBSPOT_SERVICE_KEY=
