{
  "name": "instascraper",
  "module": "src/index.ts",
  "type": "module",
  "private": true,
  "bin": {
    "instascraper": "./src/index.ts"
  },
  "scripts": {
    "cli": "bun run src/index.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:check": "bun run src/index.ts db check",
    "dev:server": "bun run --watch server/index.ts",
    "dev:web": "cd web && bun run dev",
    "dev": "concurrently -n server,web -c blue,magenta \"bun run dev:server\" \"bun run dev:web\"",
    "build:web": "cd web && bun run build",
    "build": "bun run build:web",
    "start": "NODE_ENV=production bun run server/index.ts"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/bun": "latest",
    "@types/node": "^25.0.3",
    "better-sqlite3": "^12.5.0",
    "concurrently": "^9.1.0",
    "drizzle-kit": "^0.31.8"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "commander": "^14.0.2",
    "drizzle-orm": "^0.45.1",
    "hono": "^4.6.14"
  }
}
