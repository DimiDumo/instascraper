# Cloud Worker base URL (D1 + R2 data layer).
# Prod: https://instascraper-api.<your-sub>.workers.dev (or custom domain)
# Dev: same URL works — Worker is the source of truth even locally.
VITE_CLOUD_API_URL=https://instascraper-api.<your-sub>.workers.dev

# Local orchestration server. Web polls /api/health here to detect "local-agent
# reachable" mode and unlocks scrape/generation buttons.
VITE_LOCAL_API_URL=http://localhost:3737
